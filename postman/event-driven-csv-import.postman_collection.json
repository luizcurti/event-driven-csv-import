{
  "info": {
    "_postman_id": "2b7a0fe8-8c65-4d8d-a1c9-7f5d0d0b9f6f",
    "name": "Event Driven CSV Import API",
    "description": "Requests that match the implemented Lambda handlers in this repository.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Imports",
      "item": [
        {
          "name": "Create import",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-correlation-id", "value": "{{correlationId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fileName\": \"customers.csv\",\n  \"contentType\": \"text/csv\",\n  \"body\": \"customerId,name,email,cpf,age\\n1,Alice,alice@example.com,52998224725,30\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/imports",
              "host": ["{{baseUrl}}"],
              "path": ["imports"]
            }
          }
        },
        {
          "name": "List imports",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/imports",
              "host": ["{{baseUrl}}"],
              "path": ["imports"]
            }
          }
        },
        {
          "name": "Get import by id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/imports/{{importId}}",
              "host": ["{{baseUrl}}"],
              "path": ["imports", "{{importId}}"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "importId", "value": "" },
    { "key": "correlationId", "value": "00000000-0000-0000-0000-000000000000" }
  ]
}